pkgname=uv
pkgver=0.9.7
pkgrel=0
pkgdesc="An extremely fast Python package and project manager, written in Rust."
arch=amd64
url=https://github.com/astral-sh/uv
license=MIT

source="a52c4d864058010c50403d21504cc242 https://github.com/astral-sh/uv/releases/download/${pkgver}/uv-x86_64-unknown-linux-gnu.tar.gz"

build() {
    mkdir -p ${pkgdir}/usr/bin
    install ${srcdir}/uv-x86_64-unknown-linux-gnu/uv* ${pkgdir}/usr/bin/
    #chown -R root:root ${pkgdir}
}
